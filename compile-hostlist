cd /Users/daniel/Documents/GitHub/BlockingMachine

# Create compiled blocklist
time /Users/daniel/Documents/GitHub/BlockingMachine -v -c hostlist-compiler-config.json -o BlockingMachine

# Remove all whitelisted entries, this is a blocklist after all
sed -i '/^@@/d' BlockingMachine

# Remove empty lines
sed -i '/^$/d' BlockingMachine

# Remove rules that are too long as these are most likely non DNS related rules, see https://github.com/AdguardTeam/AdGuardHome/issues/6003
sed -i '/^.\{1024\}./d' BlockingMachine

# Date and time
currentDate=`/bin/date '+%Y-%m-%d'`
currentTime=`/bin/date '+%H:%M:%S'`

# Push it to GitHub
git add *
git commit -m " update ${currentDate} ${currentTime}"
git push