{
  "name": "blockingmachine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js --server",
    "build": "npm run update-filters",
    "update-filters": "node src/index.js",
    "update-filters:ci": "node src/index.js --ci --no-progress",
    "update-release": "node src/utils/github/release.js",
    "lint": "npm run aglint && npm run eslint && npm run mdlint",
    "aglint": "aglint -c public/filters/.aglintrc.yaml public/filters/*.txt",
    "eslint": "eslint --config config/eslint.config.mjs \"src/**/*.js\"",
    "eslint:fix": "eslint --config config/eslint.config.mjs \"src/**/*.js\" --fix",
    "mdlint": "markdownlint -c config/.markdownlint.json \"./README.md\" \"./docs/**/*.md\"",
    "mdlint:fix": "markdownlint -f \"./README.md\" \"./docs/**/*.md\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:lint": "npm run lint && npm run test",
    "test:all": "npm run test:lint && npm run test:coverage && npm run test:performance",
    "test:core": "NODE_OPTIONS=--experimental-vm-modules jest tests/core/",
    "test:paths": "npm run test:core -- paths.test.js",
    "test:logger": "npm run test:core -- logger.test.js",
    "test:features": "NODE_OPTIONS=--experimental-vm-modules jest tests/rules/",
    "test:filters": "npm run test:features -- filters.test.js",
    "test:updatefilters": "npm run test:features -- updatefilters.test.js",
    "test:validator": "npm run test:features -- validator.test.js",
    "test:errors": "NODE_OPTIONS=--experimental-vm-modules jest tests/error/",
    "test:perf": "NODE_OPTIONS=--experimental-vm-modules jest tests/performance/",
    "test:memory": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=4096' jest tests/performance/memory.test.js",
    "test:stats": "NODE_OPTIONS=--experimental-vm-modules jest tests/stats/",
    "clean": "rm -rf node_modules package-lock.json && npm cache clean --force",
    "audit": "npm audit fix --force",
    "backup": "node scripts/backup-rules.js",
    "debug": "node src/index.js --debug",
    "verbose": "node src/index.js --verbose"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "axios": "^1.7.9",
    "body-parser": "^1.20.3",
    "express": "^4.21.2",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "lru-cache": "^10.2.0",
    "rimraf": "^5.0.5"
  },
  "devDependencies": {
    "@adguard/aglint": "^2.0.10",
    "@babel/core": "^7.26.9",
    "@babel/eslint-parser": "^7.26.8",
    "@babel/preset-env": "^7.26.9",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.21.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "eslint": "^9.21.0",
    "eslint-define-config": "^2.1.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "markdownlint-cli": "^0.31.1"
  },
  "engines": {
    "node": ">=20"
  }
}