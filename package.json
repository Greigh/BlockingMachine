{
  "name": "blockingmachine",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "build": "npm run start",
    "lint": "aglint",
    "lint2": "eslint -c config/eslint.config.mjs . && markdownlint -c config/.markdownlint.json '**/*.md'",
    "update-md": "node src/updateMarkdown.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "badge-maker": "^4.1.0",
    "body-parser": "^1.20.3",
    "express": "^4.21.2",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "@adguard/aglint": "^2.1.3",
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.1",
    "globals": "^16.0.0",
    "markdownlint-cli": "^0.31.1"
  },
  "engines": {
    "node": ">=20"
  },
  "env": {
    "es6": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2018
  },
  "rules": {
    "no-console": "off"
  }
}